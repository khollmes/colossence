// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum Metier {
  SERRURIER
  PLOMBIER
  ELECTRICIEN
  GARAGE
  CHAUFFAGISTE
}

enum Plan {
  MENSUEL
  ANNUEL
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PaymentType {
  SETUP_FEE
  SUBSCRIPTION
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  prenom        String
  nom           String
  email         String    @unique
  passwordHash  String
  telephone     String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // DateTime? plutôt que Boolean pour deux raisons :
  // 1. null = pas encore vérifié, une date = vérifié (pas besoin d'un champ séparé)
  // 2. On sait QUAND l'email a été vérifié, utile pour les audits et la conformité RGPD
  // C'est aussi la convention de NextAuth — si vous l'intégrez plus tard, ça sera compatible
  emailVerified DateTime?

  businessProfile     BusinessProfile?
  subscriptions       Subscription[]
  payments            Payment[]
  failedPayments      FailedPayment[]
  logs                Log[]
  verificationTokens  VerificationToken[]
}

model BusinessProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nomEntreprise        String
  siret                String
  metier               Metier
  zoneIntervention     String
  horaires             String
  tarifs               String
  telephoneATransferer String

  aiSecretaryConfig AISecretaryConfig?
}

model AISecretaryConfig {
  id                String          @id @default(cuid())
  businessProfileId String          @unique
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  consignes         String
  messageAccueil    String
  isActive          Boolean         @default(true)
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String
  stripeSubscriptionId String
  plan                 Plan
  status               SubscriptionStatus @default(TRIALING)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime
  setupFeePaid         Boolean            @default(false)
}

model Payment {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripePaymentId String
  montant         Float
  type            PaymentType
  status          String
  createdAt       DateTime    @default(now())
}

model FailedPayment {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeInvoiceId String
  montant        Float
  relances       Int      @default(0)
  resolved       Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model Log {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   Json?
  createdAt DateTime @default(now())
}

// Tokens envoyés par email pour vérifier l'adresse d'un utilisateur.
// Flux : inscription → génération token → email avec lien → clic → emailVerified rempli → token supprimé
model VerificationToken {
  id        String   @id @default(cuid())

  // Le token aléatoire inclus dans le lien envoyé par email (ex: /verify?token=abc123)
  // Unique pour qu'on puisse le retrouver directement en base sans connaître l'userId
  token     String   @unique

  // Lien vers l'utilisateur concerné
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Date limite de validité — après cette date, le lien est refusé même si le token existe
  // Typiquement now() + 24h au moment de la création
  expiresAt DateTime

  createdAt DateTime @default(now())
}
