# ─── Base de données ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# En production : URL publique exacte (sans slash final)
NEXTAUTH_URL="https://votre-domaine.com"
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET="remplacer-par-un-secret-aleatoire-32-chars"

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Clé secrète (sk_live_ en prod, sk_test_ en dev) — JAMAIS côté client
STRIPE_SECRET_KEY="sk_live_..."
# Secret du webhook (whsec_...) — récupéré dans Dashboard Stripe > Webhooks
STRIPE_WEBHOOK_SECRET="whsec_..."
# IDs des prix (récupérés dans Dashboard Stripe > Products)
STRIPE_PRICE_MENSUEL="price_..."
STRIPE_PRICE_ANNUEL="price_..."

# ─── Serveur externe de synchronisation ───────────────────────────────────────
EXTERNAL_SERVER_URL="https://api.votre-serveur.com/sync"
EXTERNAL_SERVER_API_KEY="votre-cle-api-secrete"

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="resend"
# Clé API Resend (ou mot de passe SMTP)
EMAIL_SERVER_PASSWORD="re_..."
EMAIL_FROM="Colossence <noreply@votre-domaine.com>"
